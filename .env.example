PORT=8080
DB_PATH=data/project_xray.db
MAX_BODY_BYTES=2097152
# Generate long random values; never reuse admin and reviewer credentials.
ADMIN_TOKEN=change-before-deploy
REVIEWER_TOKENS=reviewer-a:change-reviewer-a,reviewer-b:change-reviewer-b
SCANNER_TOKENS=scanner-a:change-scanner-a
BOOTSTRAP_TOKEN_TTL_SECONDS=86400
TOKEN_PEPPER=change-to-32-plus-random-characters
AUDIT_HMAC_KEY=change-to-32-plus-random-characters
BACKUP_HMAC_KEY=change-to-32-plus-random-characters
OIDC_PROXY_SECRET=change-to-32-plus-random-characters
WRITE_RATE_LIMIT=60
APP_ENV=development
PUBLIC_BASE_URL=http://localhost:8080
OBJECT_STORAGE_MODE=local
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_BUCKET=
STORAGE_REGION=ap-south-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
MONITORING_WEBHOOK_URL=
MONITORING_WEBHOOK_SECRET=
