# Allowlist for gitleaks false positives
# These are example/template files with placeholder values, not real secrets

[[allowlist]]
description = "Example/template env files use placeholder passwords"
paths = [
    '''\.env\.production\.example$''',
    '''\.env\.example$''',
]
regexes = [
    '''change-to-strong-password''',
    '''change-before-deploy''',
    '''change-to-32-plus-random-characters''',
]

[[allowlist]]
description = "Docker compose files use variable substitution, not real secrets"
paths = [
    '''docker-compose\.prod\.yml$''',
    '''docker-compose\.yml$''',
]

[[allowlist]]
description = "Test files use known test tokens"
paths = [
    '''tests/.*\.py$''',
    '''scripts/.*\.py$''',
    '''scripts/.*\.mjs$''',
]
regexes = [
    '''test-admin-secret-long-enough''',
    '''review-token-a''',
    '''review-token-b''',
    '''scan-token-a''',
    '''ui-admin-token-12345678901234567890''',
    '''ui-review-token-a''',
    '''ui-review-token-b''',
    '''ui-scan-token-a''',
    '''smoke-admin-token-123456789''',
    '''smoke-reviewer-a-token''',
    '''smoke-reviewer-b-token''',
]

[[allowlist]]
description = "Audit report references security concepts but contains no real secrets"
paths = [
    '''AUDIT_REPORT\.md$''',
]

[[allowlist]]
description = "Production deployment docs reference env var names"
paths = [
    '''docs/.*\.md$''',
]
