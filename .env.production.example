# ─────────────────────────────────────────────────────────────────────
# Project X-Ray India — Production Environment Template
#
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to version control.
#
# All keys marked with [SECRET] must be 32+ random characters from a
# secret manager (e.g. `python3 -c "import secrets; print(secrets.token_urlsafe(48))"`).
# ─────────────────────────────────────────────────────────────────────

# ── PostgreSQL Database ──────────────────────────────────────────────
# The application uses DATABASE_URL when set; otherwise falls back to
# SQLite via DB_PATH. In production, always use PostgreSQL.
POSTGRES_DB=xray
POSTGRES_USER=xray
# [SECRET] Strong password for the PostgreSQL application user.
POSTGRES_PASSWORD=change-to-strong-password
# Full connection string (auto-constructed in docker-compose.prod.yml,
# but documented here for standalone deployments).
# DATABASE_URL=postgresql://xray:change-to-strong-password@db:5432/xray
# Connection pool size for psycopg2 ThreadedConnectionPool.
DB_POOL_MAX=10

# ── Server ───────────────────────────────────────────────────────────
PORT=8080
# Maximum request body size in bytes (2 MiB default).
MAX_BODY_BYTES=2097152
# MUST be "production" in production. Disables bootstrap tokens,
# enforces OIDC proxy boundary.
APP_ENV=production
# Public-facing HTTPS URL. Must match the domain users access.
PUBLIC_BASE_URL=https://xray-india.example.org

# ── Authentication Tokens ────────────────────────────────────────────
# [SECRET] Admin bootstrap token. Rotate after initial setup.
ADMIN_TOKEN=change-to-32-plus-random-characters
# [SECRET] Reviewer tokens in format name:token,name:token
REVIEWER_TOKENS=reviewer-a:change-reviewer-a,reviewer-b:change-reviewer-b
# [SECRET] Scanner tokens in format name:token
SCANNER_TOKENS=scanner-a:change-scanner-a
# TTL for bootstrap tokens in seconds (24 hours default).
BOOTSTRAP_TOKEN_TTL_SECONDS=86400

# ── Security Keys ────────────────────────────────────────────────────
# [SECRET] Pepper for token hashing (HMAC). 32+ random characters.
TOKEN_PEPPER=change-to-32-plus-random-characters
# [SECRET] HMAC key for audit log chain integrity. 32+ random characters.
AUDIT_HMAC_KEY=change-to-32-plus-random-characters
# [SECRET] HMAC key for backup integrity verification. 32+ random characters.
BACKUP_HMAC_KEY=change-to-32-plus-random-characters
# [SECRET] Shared secret for OIDC proxy signature verification.
# The identity-aware gateway signs X-Auth-* headers with this key.
# The gateway-to-app network must be private and strip client-supplied
# X-Auth-* headers.
OIDC_PROXY_SECRET=change-to-32-plus-random-characters
# Frozen downstream gateway assertion contract.
GATEWAY_ASSERTION_VERSION=1
GATEWAY_ASSERTION_AUDIENCE=project-xray-app
GATEWAY_ASSERTION_ISSUERS=https://cognito-idp.ap-south-1.amazonaws.com/POOL_ID
GATEWAY_ASSERTION_KEY_ID=gateway-production-2026-07

# ── Rate Limiting ────────────────────────────────────────────────────
# Max writes per minute per identity.
WRITE_RATE_LIMIT=60
# Max public (unauthenticated) reads per minute per IP.
PUBLIC_READ_RATE_LIMIT=300
# Max authenticated reads per minute per identity.
AUTH_READ_RATE_LIMIT=120
# Max expensive writes (e.g. publication) per minute per identity.
EXPENSIVE_WRITE_RATE_LIMIT=15

# ── Proxy / OIDC Configuration ──────────────────────────────────────
# Trust X-Auth-* headers from the OIDC proxy gateway.
# Only enable when the app is behind a trusted reverse proxy that
# strips client-supplied X-Auth-* headers.
TRUST_PROXY_HEADERS=1

# ── Object Storage (S3-compatible) ───────────────────────────────────
# Must be "managed" in production (uses S3-compatible API).
# "local" mode stores files on disk and is for development only.
OBJECT_STORAGE_MODE=managed
# S3-compatible endpoint URL. Leave empty on AWS so botocore selects the
# regional endpoint. Set an HTTPS URL for MinIO/other S3-compatible services.
STORAGE_ENDPOINT=
# Bucket name for document storage.
STORAGE_BUCKET=
# AWS region or S3-compatible region.
STORAGE_REGION=ap-south-1
# Optional [SECRET] static S3 access key. Leave both values empty on ECS;
# botocore then uses the task role through the AWS default credential chain.
STORAGE_ACCESS_KEY=
# Optional [SECRET] static S3 secret access key. Must be set together with
# STORAGE_ACCESS_KEY.
STORAGE_SECRET_KEY=
# Optional [SECRET] session token when temporary static credentials are used.
STORAGE_SESSION_TOKEN=

# Evidence records in production must use a version-bound URI:
# s3://BUCKET/KEY?versionId=EXACT_VERSION_ID

# ── Monitoring / Alerting ────────────────────────────────────────────
# Webhook URL for incident/alert notifications (e.g. Slack, PagerDuty).
# The app sends POST requests with HMAC-signed payloads to this URL.
MONITORING_WEBHOOK_URL=
# [SECRET] HMAC secret for signing monitoring webhook payloads.
MONITORING_WEBHOOK_SECRET=change-to-32-plus-random-characters
